# ─────────────────────────────────────────────────────────────────────────────
# Personal AI Employee — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in your real values
#   3. NEVER commit .env to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Vault Path ─────────────────────────────────────────────────────────────────
# Absolute path to your AI_Employee_Vault folder
# Windows example: C:\Users\YourName\Downloads\ai employee\AI_Employee_Vault
# Mac/Linux example: /Users/yourname/ai-employee/AI_Employee_Vault
VAULT_PATH=./AI_Employee_Vault

# ── Claude Code ────────────────────────────────────────────────────────────────
# Path to the claude binary (usually just "claude" if installed globally)
CLAUDE_BIN=claude

# ── Safety ─────────────────────────────────────────────────────────────────────
# Set to "true" during development/testing — no real external actions taken
DRY_RUN=true

# Max concurrent Claude Code sessions
MAX_CLAUDE_SESSIONS=3

# How often orchestrator checks for new items (seconds)
CHECK_INTERVAL=30

# ── Gmail API (Bronze/Silver Tier) ─────────────────────────────────────────────
# Download credentials.json from Google Cloud Console
# → APIs & Services → Credentials → Create OAuth 2.0 Client ID
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json

# ── WhatsApp (Silver Tier) ─────────────────────────────────────────────────────
# Path to store Playwright browser session (keeps you logged in to WhatsApp Web)
WHATSAPP_SESSION_PATH=./whatsapp_session

# ── Banking API (Gold Tier) ─────────────────────────────────────────────────────
# Your bank's API token (if they provide one — e.g. Plaid, Basiq, etc.)
BANK_API_TOKEN=your_bank_api_token_here
BANK_API_BASE_URL=https://api.yourbank.com

# ── Social Media (Silver/Gold Tier) ────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# ── Odoo (Gold Tier) ───────────────────────────────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=your_odoo_database
ODOO_USERNAME=admin
ODOO_PASSWORD=your_odoo_password

# ── Notifications ──────────────────────────────────────────────────────────────
# Optional: get notified when the watchdog restarts a process
# NOTIFICATION_EMAIL=you@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your_app_password
